# Streamlit Cloud Secrets Configuration Template
# Copy this format to your Streamlit Cloud app secrets

# Qdrant Cloud Configuration
QDRANT_URL = "https://your-cluster-id.us-east-1-0.aws.cloud.qdrant.io:6333"
QDRANT_API_KEY = "your-qdrant-api-key-here"

# Application Configuration  
ENVIRONMENT = "production"

# Optional: Cloud Storage URLs for Data Files
# If you host your data files in cloud storage, set these URLs:
# CHARITY_DATA_URL = "https://your-storage.com/publicextract.charity.json"
# CLASSIFICATION_DATA_URL = "https://your-storage.com/publicextract.charity_classification.json"
# OTHER_NAMES_DATA_URL = "https://your-storage.com/publicextract.charity_other_names.json"
# TRUSTEES_DATA_URL = "https://your-storage.com/publicextract.charity_trustee.json" 