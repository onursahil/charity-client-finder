# Environment Variables for Local Development
# Copy this file to .env and update with your actual values

# Qdrant Configuration (choose one method)

# Method 1: Cloud URL (for Qdrant Cloud)
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key-here

# Method 2: Host/Port (for local Qdrant or custom cloud setup)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_API_KEY=your-api-key-if-needed

# Application Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
STREAMLIT_SERVER_PORT=8501
DEFAULT_SCORE_THRESHOLD=0.3
DEFAULT_FUZZY_THRESHOLD=70 